{
  "name": "@farihatang/react-ui",
  "version": "0.1.0-beta.3",
  "description": "A React component library to help you build your own GitHub projects more easily.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "keywords": [
    "react",
    "component-library",
    "ui",
    "navbar"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/FarihaTang/react-component-library"
  },
  "homepage": "https://react-component-library-farihatang.vercel.app/",
  "bugs": {
    "url": "https://github.com/FarihaTang/react-component-library/issues"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean && npx tailwindcss -i ./src/styles.css -o ./dist/index.css --minify",
    "build-storybook": "storybook build",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.1.9",
    "@storybook/addon-interactions": "^8.1.9",
    "@storybook/addon-links": "^8.1.9",
    "@storybook/blocks": "^8.1.9",
    "@storybook/react": "^8.1.9",
    "@storybook/react-vite": "^8.1.9",
    "@storybook/test": "^8.1.9",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "storybook": "^8.1.9",
    "tailwindcss": "^3.4.4",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.13"
  }
}
